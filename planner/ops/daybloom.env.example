# Copy this file to  daybloom.env  and fill in your own values.
#   cp daybloom.env.example daybloom.env
# daybloom.env is git-ignored so your secrets never get committed.

# The passcode you'll type to open the app on your phone. Pick something only you know.
DAYBLOOM_PASSCODE=change-me

# Your Anthropic API key (the one from HW 11). Powers smart logging + reviews.
ANTHROPIC_API_KEY=sk-ant-...

# Leave these two blank — install.sh generates strong random values for you and
# writes them back here. (SECRET keeps your login secure; INGEST_TOKEN is the
# password the Apple Health Shortcut uses to send in your data.)
DAYBLOOM_SECRET=
DAYBLOOM_INGEST_TOKEN=

# Port the app listens on locally. 3000 is fine unless something else uses it.
PORT=3000
